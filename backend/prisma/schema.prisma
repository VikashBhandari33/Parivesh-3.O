// This is your Prisma schema file
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ──────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  PROPONENT
  SCRUTINY
  MOM_TEAM
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_SCRUTINY
  EDS
  REFERRED
  MOM_GENERATED
  FINALIZED
}

enum DocumentType {
  FORM_1
  FORM_1A
  ENVIRONMENTAL_IMPACT_ASSESSMENT
  PRE_FEASIBILITY_REPORT
  MAP_TOPOSHEET
  FOREST_CLEARANCE
  WATER_CONSENT
  NOC
  OTHER
}

enum NotificationType {
  EMAIL
  SMS
  WHATSAPP
  IN_APP
  PUSH
}

// ─── MODELS ─────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         UserRole  @default(PROPONENT)
  name         String
  organization String?
  phone        String?
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  applications    Application[]   @relation("ProponentApplications")
  auditEvents     AuditChain[]
  edsIssued       EdsNotice[]     @relation("EdsIssuedBy")
  paymentsVerified Payment[]      @relation("PaymentVerifiedBy")
  notifications   Notification[]

  @@map("users")
}

model Application {
  id          String            @id @default(uuid())
  proponentId String            @map("proponent_id")
  projectName String            @map("project_name")
  sector      String
  description String?
  status      ApplicationStatus @default(DRAFT)

  // Location
  district    String?
  state       String            @default("Chhattisgarh")
  lat         Float?
  lng         Float?

  // Satellite Verification Results
  satelliteRiskScore Int?   @map("satellite_risk_score")
  satelliteReport    Json?  @map("satellite_report")

  // Project Details
  areaHa      Float?  @map("area_ha")
  investmentCr Float? @map("investment_cr")
  employmentCount Int? @map("employment_count")

  // Fee
  feeAmount   Float?  @map("fee_amount")
  feePaid     Boolean @default(false) @map("fee_paid")

  // MoM
  gistText    String? @map("gist_text")
  momText     String? @map("mom_text")
  momLocked   Boolean @default(false) @map("mom_locked")
  momLockedAt DateTime? @map("mom_locked_at")

  // SLA
  slaDeadline DateTime? @map("sla_deadline")
  escalated   Boolean   @default(false)

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  submittedAt DateTime? @map("submitted_at")

  // Relations
  proponent    User          @relation("ProponentApplications", fields: [proponentId], references: [id])
  documents    Document[]
  payment      Payment?
  edsNotices   EdsNotice[]
  auditEvents  AuditChain[]
  gisRiskFlags GisRiskFlag[]

  @@map("applications")
}

model Document {
  id            String       @id @default(uuid())
  applicationId String       @map("application_id")
  docType       DocumentType @map("doc_type")
  fileName      String       @map("file_name")
  fileUrl       String       @map("file_url")
  fileHash      String       @map("file_hash")
  fileSizeBytes Int          @map("file_size_bytes")
  mimeType      String       @map("mime_type")
  ocrText       String?      @map("ocr_text")
  verified      Boolean      @default(false)
  scanned       Boolean      @default(false)
  pqcSignature  String?      @map("pqc_signature")
  pqcPublicKey  String?      @map("pqc_public_key")
  uploadedAt    DateTime     @default(now()) @map("uploaded_at")

  // Relations
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("documents")
}

model Payment {
  id            String    @id @default(uuid())
  applicationId String    @unique @map("application_id")
  amount        Float
  utrNumber     String?   @map("utr_number")
  qrCodeUrl     String?   @map("qr_code_url")
  upiId         String?   @map("upi_id")
  verifiedAt    DateTime? @map("verified_at")
  verifiedById  String?   @map("verified_by_id")
  createdAt     DateTime  @default(now()) @map("created_at")

  // Relations
  application  Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  verifiedBy   User?       @relation("PaymentVerifiedBy", fields: [verifiedById], references: [id])

  @@map("payments")
}

model EdsNotice {
  id            String    @id @default(uuid())
  applicationId String    @map("application_id")
  deficiencies  Json      // Array of deficiency objects
  issuedById    String    @map("issued_by_id")
  issuedAt      DateTime  @default(now()) @map("issued_at")
  resolvedAt    DateTime? @map("resolved_at")
  remarks       String?

  // Relations
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  issuedBy    User        @relation("EdsIssuedBy", fields: [issuedById], references: [id])

  @@map("eds_notices")
}

model AuditChain {
  id            Int      @id @default(autoincrement())
  eventType     String   @map("event_type")
  actorId       String   @map("actor_id")
  applicationId String?  @map("application_id")
  payload       Json?
  payloadHash   String   @map("payload_hash")  // SHA3-256(payload)
  prevHash      String   @map("prev_hash")      // hash of previous row
  chainHash     String   @map("chain_hash")     // SHA3-256(prev_hash + payload_hash)
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  actor       User         @relation(fields: [actorId], references: [id])
  application Application? @relation(fields: [applicationId], references: [id])

  @@map("audit_chain")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  message   String
  title     String?
  read      Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model GisRiskFlag {
  id            String   @id @default(uuid())
  applicationId String   @map("application_id")
  flagType      String   @map("flag_type")   // FOREST, RIVER, SANCTUARY, WETLAND
  distanceM     Float    @map("distance_m")
  layerName     String   @map("layer_name")
  severity      String   @default("HIGH")    // HIGH, MEDIUM, LOW
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("gis_risk_flags")
}

model MomTemplate {
  id        String   @id @default(uuid())
  name      String
  sector    String?
  content   String   // TipTap JSON or HTML
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("mom_templates")
}
